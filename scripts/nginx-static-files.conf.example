# isucon.conf の location / を try_files 化（静的ファイルを nginx 直接配信）
# 反映後: sudo nginx -t && sudo systemctl reload nginx
#
# 変更前:
#   location / {
#     proxy_set_header Host $host;
#     proxy_pass http://localhost:8080;
#   }
#
# 変更後:

  location / {
    try_files $uri @app;
  }

  location @app {
    proxy_set_header Host $host;
    proxy_pass http://127.0.0.1:8080;
  }
